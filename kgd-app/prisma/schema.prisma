// KGD Account Tracking — Prisma Schema
// Stack: PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
}

enum ProductType {
  PLATE
  SHEET
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum StockMoveType {
  PURCHASE    // stock came in (raw material purchase)
  ADJUSTMENT  // manual correction
  USAGE       // manually record usage
}

// ─────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdInvoices  Invoice[]
  createdPayments  Payment[]
  createdInventory InventoryTransaction[]
  auditLogs        AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @default(cuid())
  // name = Contact Person (kept for backward compat)
  name            String
  businessName    String?
  phone           String?   // primary phone number
  secondaryPhone  String?   // secondary / alternate phone
  address         String?
  city            String?
  notes           String?
  // Advance credit balance — accumulated from unallocated payments
  creditBalance   Decimal   @default(0) @db.Decimal(12, 2)
  // Soft hint for discounts — always overridable at billing time
  defaultDiscount Decimal?  @db.Decimal(5, 2)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  contacts  CustomerContact[]
  invoices  Invoice[]
  payments  Payment[]

  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  phone      String?
  role       String?   // e.g. "Owner", "Manager", "Accountant"
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  name        String      // e.g. "10 inch Silver Plate 80 GSM"
  type        ProductType
  sizeInches  Decimal?    @db.Decimal(5, 2)  // e.g. 10.00, 14.00
  gsm         Int?                            // e.g. 70, 80, 100, 120, 140
  color       String?                         // e.g. Silver, Gold, Green, Multi
  // Default unit for this product; invoice items can override
  unitLabel   String      @default("packet") // "packet" | "piece" | "kg" | "sheet"
  // Suggested rate — always manually overridable at invoice line level
  defaultRate Decimal?    @db.Decimal(10, 2)
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  invoiceItems InvoiceItem[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // e.g. KGD-2024-0001
  customerId    String
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  // Amounts — all stored in INR
  subtotal      Decimal       @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal       @db.Decimal(12, 2)  // subtotal - discountAmount
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2) // sum of allocations
  balanceDue    Decimal       @db.Decimal(12, 2)  // totalAmount - paidAmount
  status        InvoiceStatus @default(UNPAID)
  remarks       String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer    Customer            @relation(fields: [customerId], references: [id])
  createdBy   User                @relation(fields: [createdById], references: [id])
  items       InvoiceItem[]
  allocations PaymentAllocation[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?  // nullable — allows free-text manual line items
  // Description always stored — auto-filled from product or manually typed
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unit        String   @default("packet")
  // Rate ALWAYS manually entered or confirmed — never auto-applied silently
  rate        Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(12, 2)  // quantity × rate
  remarks     String?
  sortOrder   Int      @default(0)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ─────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  customerId  String
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime      @default(now())
  method      PaymentMethod @default(CASH)
  reference   String?       // UPI txn ID, cheque number, bank ref, etc.
  notes       String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer    Customer            @relation(fields: [customerId], references: [id])
  createdBy   User                @relation(fields: [createdById], references: [id])
  allocations PaymentAllocation[]

  @@map("payments")
}

// One payment can be allocated across multiple invoices
model PaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal @db.Decimal(12, 2)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([paymentId, invoiceId])
  @@map("payment_allocations")
}

// ─────────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────────

model InventoryItem {
  id           String   @id @default(cuid())
  name         String   // e.g. "Brown Paper 700mm 80GSM"
  category     String   // e.g. "Brown Paper", "Threads", "Films", "Gum Bags", "Covers", "Packing"
  unit         String   // "kg" | "roll" | "piece" | "bundle"
  currentStock Decimal  @db.Decimal(12, 3)  // manually maintained
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  inventoryItemId String
  type            StockMoveType
  quantity        Decimal       @db.Decimal(12, 3) // positive = in, negative = out
  rate            Decimal?      @db.Decimal(10, 2) // cost per unit (for PURCHASE)
  totalCost       Decimal?      @db.Decimal(12, 2) // qty × rate
  transactionDate DateTime      @default(now())
  notes           String?
  createdById     String
  createdAt       DateTime      @default(now())

  item        InventoryItem @relation(fields: [inventoryItemId], references: [id])
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@map("inventory_transactions")
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  entity      String   // "Invoice" | "Payment" | "Customer" | "Product" | "Inventory"
  entityId    String
  action      String   // "CREATE" | "UPDATE" | "DELETE"
  oldValues   Json?    // snapshot of fields before change
  newValues   Json?    // snapshot of fields after change
  performedBy String   // userId
  performedAt DateTime @default(now())
  ip          String?

  user User @relation(fields: [performedBy], references: [id])

  @@map("audit_logs")
}
